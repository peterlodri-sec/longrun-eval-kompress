{
  "name": "loop-experiment-researcher",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefaultShell": true,
      "username": "vscode",
      "userUid": "1000",
      "userGid": "1000"
    },
    "ghcr.io/devcontainers/features/git:1": {
      "version": "latest",
      "ppa": true
    },
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12",
      "installTools": true,
      "enableShared": true
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20",
      "nodeGnukey": true
    }
  },
  "postCreateCommand": "pip install --user marimo mcp headroom-ai sumy nltk llmlingua 2>/dev/null; python -c \"import nltk; nltk.download('punkt_tab', quiet=True); nltk.download('punkt', quiet=True)\" 2>/dev/null; echo 'Dev container ready. Run: marimo edit notebook.py'",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "LaTeX-Workshop.latex-workshop",
        "marimo-team.marimo",
        "ms-azuretools.vscode-docker",
        "redhat.vscode-yaml",
        "GitHub.copilot",
        "ms-toolsai.vscode-jupyter-cell-renderers"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.terminal.activateEnvironment": true,
        "latex-workshop.latex.autoBuild.run": "onSave",
        "latex-workshop.latex.outDir": "%DIR%/aux",
        "editor.formatOnSave": true,
        "editor.rulers": [80, 120],
        "files.associations": {
          "*.tex": "latex",
          "AGENTS.md": "markdown",
          "LINKS.txt": "plaintext"
        },
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  },
  "forwardPorts": [8765, 2718],
  "portsAttributes": {
    "8765": { "label": "MCP Server (HTTP)", "onAutoForward": "notify" },
    "2718": { "label": "Marimo Notebook", "onAutoForward": "openBrowser" }
  },
  "remoteEnv": {
    "MCP_SERVER_PORT": "8765",
    "MARIMO_PORT": "2718"
  },
  "mounts": [
    "source=${localWorkspaceFolderBasename}-hf-cache,target=/home/vscode/.cache/huggingface,type=volume"
  ]
}
